{
    "name": "@spin-wheel/embed",
    "version": "1.0.0",
    "type": "module",
    "sideEffects": false,
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        },
        "./global": "./dist/spin-wheel.global.js"
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsdown && node build-global.mjs",
        "build:global": "node build-global.mjs",
        "dev": "vite"
    },
    "dependencies": {
        "@spin-wheel/core": "workspace:*",
        "@spin-wheel/renderer": "workspace:*",
        "@spin-wheel/widget": "workspace:*"
    },
    "devDependencies": {
        "esbuild": "^0.27.3",
        "tsdown": "0.21.0-beta.2",
        "typescript": "^5.9.3",
        "vite": "^7.3.1"
    }
}
