{
    "name": "@spin-wheel/widget",
    "version": "1.0.0",
    "type": "module",
    "sideEffects": false,
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
