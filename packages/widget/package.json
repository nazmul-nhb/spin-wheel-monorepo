        "watch": "tsdown --watch"
    },
    "peerDependencies": {
        "@spin-wheel/core": "workspace:*",
        "@spin-wheel/renderer": "workspace:*"
    },
    "dependencies": {
        "@spin-wheel/core": "workspace:*",
        "@spin-wheel/renderer": "workspace:*"
    },
    "devDependencies": {
        "tsdown": "0.21.0-beta.2",
        "typescript": "^5.9.3"
